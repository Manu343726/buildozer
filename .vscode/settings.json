{
  "editor.formatOnSave": true,
  "[proto]": {
    "editor.defaultFormatter": "bufbuild.vscode-buf",
    "editor.formatOnSave": true,
     "editor.codeActionsOnSave": {
      "source.organizeImports": "always"
    }
  },
  "buf.lint.runOnSave": true,
  "buf.breakingChecks.runOnSave": false,
  "buf.checkForUpdates": true,
  "[protobuf]": {
    "editor.defaultFormatter": "bufbuild.vscode-buf"
  },
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "go.lintTool": "golangci-lint",
  "go.lintOnSave": "package",
  "cmake.sourceDirectory": "/workspaces/buildozer/examples/cmake_project",
  "workbench.colorCustomizations": {
    "editor.foreground": "#cccccc",
    "editor.background": "#000000",
    "terminal.background": "#000000",
    "terminal.foreground": "#cccccc",
    "debugConsole.sourceForeground": "#cccccc",
    "debugConsoleInputBorder": "#666666",
    "debugConsoleErrorIconForeground": "#ff9999",
    "editorForeground": "#cccccc",
    "editorBackground": "#000000"
  }
}